generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id              Int             @id @default(autoincrement())
  name            String          @db.VarChar(100)
  phone           String?         @db.VarChar(20)
  email           String?         @db.VarChar(255)
  birth_date      DateTime?       @db.Date
  address         String?
  notes           String?
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  updated_at      DateTime?       @default(now()) @db.Timestamp(6)
  birthday        DateTime?       @db.Date
  adjustments     Adjustment[]
  member_services MemberService[]
  service_logs    ServiceLog[]

  @@map("customers")
}

model Service {
  id               Int             @id @default(autoincrement())
  name             String          @db.VarChar(100)
  description      String?
  price            Decimal?        @db.Decimal(10, 2)
  created_at       DateTime?       @default(now()) @db.Timestamp(6)
  updated_at       DateTime?       @default(now()) @db.Timestamp(6)
  duration_minutes Int             @default(60)
  is_active        Boolean?        @default(true)
  member_services  MemberService[]
  service_logs     ServiceLog[]

  @@map("services")
}

model MemberService {
  id                Int          @id @default(autoincrement())
  customer_id       Int?         // 根据实际约束，可能应为非空，暂时保留可选
  service_id        Int?
  total_sessions    Int          @default(0)   // 对应数据库 total_sessions
  remaining_sessions Int        @default(0) @map("remaining_sessions") // 对应数据库 remaining_sessions
  purchased_at      DateTime?    @default(now()) @db.Timestamp(6)
  expires_at        DateTime?    @db.Timestamp(6)
  expiry_date       DateTime?    @db.Date      // 如果数据库有此列，保留；否则删除
  created_at        DateTime?    @default(now()) @db.Timestamp(6)
  updated_at        DateTime?    @default(now()) @updatedAt @db.Timestamp(6)
  adjustments       Adjustment[]
  customer          Customer?    @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service           Service?     @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service_logs      ServiceLog[]

  @@unique([customer_id, service_id], map: "unique_customer_service")
  @@map("member_services")
}

model ServiceLog {
  id                Int            @id @default(autoincrement())
  customer_id       Int?
  member_service_id Int?
  service_id        Int?
  used_at           DateTime?      @default(now()) @db.Timestamp(6)
  notes             String?
  signature_url     String?
  created_by        Int?
  created_at        DateTime?      @default(now()) @db.Timestamp(6)
  users             users?         @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer          Customer?      @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  member_service    MemberService? @relation(fields: [member_service_id], references: [id], onUpdate: NoAction)
  service           Service?       @relation(fields: [service_id], references: [id], onUpdate: NoAction)

  @@map("service_logs")
}

model Adjustment {
  id                Int            @id @default(autoincrement())
  customer_id       Int?
  member_service_id Int?
  adjustment_type   String?        @db.VarChar(20)
  amount            Int
  reason            String?
  created_at        DateTime?      @default(now()) @db.Timestamp(6)
  created_by        Int?
  users             users?         @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers         Customer?      @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  member_service    MemberService? @relation(fields: [member_service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("adjustments")
}

model products {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?
  price       Decimal?  @db.Decimal(10, 2)
  image_url   String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  stock       Int?      @default(0)
}

model users {
  id            Int          @id @default(autoincrement())
  email         String       @unique @db.VarChar(255)
  password_hash String       @db.VarChar(255)
  full_name     String?      @db.VarChar(100)
  role          String?      @default("admin") @db.VarChar(50)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  updated_at    DateTime?    @default(now()) @db.Timestamp(6)
  adjustments   Adjustment[]
  service_logs  ServiceLog[]
}
