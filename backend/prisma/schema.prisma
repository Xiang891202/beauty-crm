generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  password_hash  String
  role           String   @default("admin")
  created_at     DateTime @default(now())
}

model Customer {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String?  @unique
  birthday   DateTime?
  notes      String?
  created_at DateTime @default(now())

  member_services MemberService[]
  service_logs    ServiceLog[]
  transactions    Transaction[]

  @@map("customers")

}

model Service {
  id               Int      @id @default(autoincrement())
  name             String
  price            Float
  duration_minutes Int      @default(60)
  description      String?
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())

  member_services MemberService[]
  service_logs    ServiceLog[]
  transactions    Transaction[]

  @@map("services")
}

model MemberService {
  id             Int      @id @default(autoincrement())
  customer_id    Int
  service_id     Int
  total_sessions Int
  remaining      Int      @map("remaining_sessions")   // ✅ 關鍵修正
  expiry_date    DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id])
  service  Service  @relation(fields: [service_id], references: [id])

  transactions Transaction[]
  service_logs ServiceLog[]
  adjustments  Adjustment[]

  @@map("member_services")
}

model ServiceLog {
  id                Int      @id @default(autoincrement())
  customer_id       Int
  service_id        Int?
  member_service_id Int
  used_at           DateTime @default(now())
  notes              String?          // ✅ 使用 note (單數)
  signature_url     String?
  created_at        DateTime @default(now())
  created_by        Int?

  customer       Customer      @relation(fields: [customer_id], references: [id])
  service        Service?      @relation(fields: [service_id], references: [id])
  member_service MemberService @relation(fields: [member_service_id], references: [id])

  @@map("service_logs")
}

model Adjustment {
  id               Int      @id @default(autoincrement())
  member_service_id Int
  adjustment_type   String   @db.VarChar(20)
  amount            Int
  reason            String?
  created_by        Int?
  created_at        DateTime @default(now())

  member_service MemberService @relation(fields: [member_service_id], references: [id])

  @@map("adjustments")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  stock       Int      @default(0)
  description String?
  image_url   String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Transaction {
  id                 Int      @id @default(autoincrement())
  member_service_id  Int
  customer_id        Int
  service_id         Int
  type               String   @db.VarChar(20)
  amount             Int
  remaining_after    Int
  signature_url      String?
  note               String?
  created_by         Int?
  created_at         DateTime @default(now())

  member_service MemberService @relation(fields: [member_service_id], references: [id])
  customer       Customer      @relation(fields: [customer_id], references: [id])
  service        Service       @relation(fields: [service_id], references: [id])
}